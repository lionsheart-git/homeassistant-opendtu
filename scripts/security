#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

if [[ -x "${HOME}/.local/bin/uv" ]]; then
    export PATH="${HOME}/.local/bin:${PATH}"
fi

uv run bandit -q -r custom_components/opendtu -x tests

audit_requirements="$(mktemp)"
trap 'rm -f "${audit_requirements}"' EXIT

uv export --no-hashes --group dev --format requirements-txt --output-file "${audit_requirements}" >/dev/null

# Home Assistant 2026.3.2 pins these transitive dependencies exactly. Keep this
# list narrow so newly introduced or newly disclosed vulnerabilities still fail.
uv run pip-audit \
    --strict \
    --progress-spinner off \
    --requirement "${audit_requirements}" \
    --ignore-vuln CVE-2026-34515 \
    --ignore-vuln CVE-2026-34513 \
    --ignore-vuln CVE-2026-34516 \
    --ignore-vuln CVE-2026-34517 \
    --ignore-vuln CVE-2026-34519 \
    --ignore-vuln CVE-2026-34518 \
    --ignore-vuln CVE-2026-34520 \
    --ignore-vuln CVE-2026-34525 \
    --ignore-vuln CVE-2026-22815 \
    --ignore-vuln CVE-2026-34514 \
    --ignore-vuln CVE-2026-34073 \
    --ignore-vuln CVE-2026-39892 \
    --ignore-vuln CVE-2026-40192 \
    --ignore-vuln CVE-2026-42308 \
    --ignore-vuln CVE-2026-42309 \
    --ignore-vuln CVE-2026-42310 \
    --ignore-vuln CVE-2026-42311 \
    --ignore-vuln CVE-2026-32597 \
    --ignore-vuln CVE-2026-27448 \
    --ignore-vuln CVE-2026-27459 \
    --ignore-vuln CVE-2026-25645 \
    --ignore-vuln GHSA-pjjw-68hj-v9mw
